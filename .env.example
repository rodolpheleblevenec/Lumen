# Modèle d'environnement — copier vers .env.local et remplir.
# ⚠️ Aucune vraie valeur ici : ce fichier est versionné sur GitHub.

# ── Supabase ─────────────────────────────────────────────
# Projet : https://supabase.com/dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role : serveur uniquement, ne JAMAIS exposer côté client
SUPABASE_SERVICE_ROLE_KEY=

# ── OpenAI (génération des leçons) ───────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5

# ── Cron (Cloud Scheduler → route API protégée) ──────────
CRON_SECRET=

# ── Web Push VAPID (V1) — générer avec `npx web-push generate-vapid-keys`
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=
